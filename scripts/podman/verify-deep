#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/common.sh"

ENGINE="/workspace/.cargo-target/release/labzero"
if [[ ! -x "${ENGINE}" ]]; then
  "${SCRIPT_DIR}/build-engine"
fi

STARTPOS="rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1"

echo "==> deep perft crosscheck"
"${SCRIPT_DIR}/run" python3 verifier/python/perft_crosscheck.py "${ENGINE}" --depth 6

echo "==> fuzz 200 games"
"${SCRIPT_DIR}/run" python3 verifier/python/random_position_fuzzer.py "${ENGINE}" --games 200 --max-plies 120 --seed 42

echo "==> legality oracle (full)"
"${SCRIPT_DIR}/run" python3 verifier/python/legality_oracle.py "${ENGINE}"

echo "==> cozy crosscheck"
"${SCRIPT_DIR}/run" cargo build --release --manifest-path verifier/rust/cozy_crosscheck/Cargo.toml
COZY="/workspace/.cargo-target/release/cozy_crosscheck"
for depth in 1 2 3 4; do
  "${SCRIPT_DIR}/run" "${COZY}" "${ENGINE}" "${depth}" "${STARTPOS}"
done

echo "==> shakmaty crosscheck"
"${SCRIPT_DIR}/run" cargo build --release --manifest-path verifier/rust/shakmaty_crosscheck/Cargo.toml
SHAK="/workspace/.cargo-target/release/shakmaty_crosscheck"
for depth in 1 2 3 4; do
  "${SCRIPT_DIR}/run" "${SHAK}" "${ENGINE}" "${depth}" "${STARTPOS}"
done

echo "verify-deep: PASS"
