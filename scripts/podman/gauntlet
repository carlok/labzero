#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/common.sh"

"${SCRIPT_DIR}/build-engine"
ENGINE="/workspace/.cargo-target/release/labzero"

SMOKE=0
GAMES="${GAUNTLET_GAMES:-100}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --smoke) SMOKE=1; GAMES=10; shift ;;
    --games) GAMES="$2"; shift 2 ;;
    *) shift ;;
  esac
done

ARGS=("${ENGINE}" fastchess --games "${GAMES}")
if [[ "${SMOKE}" == "1" ]]; then
  ARGS+=(--smoke)
fi

"${SCRIPT_DIR}/run" bash tournaments/fastchess/gauntlet.sh "${ARGS[@]}"
